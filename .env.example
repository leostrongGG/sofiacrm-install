# =============================================================
# SofiaCRM — Exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# Gere senhas/tokens com: openssl rand -hex 32
# =============================================================

# Domínio e e-mail (usado pelo Traefik / Let's Encrypt)
CRM_DOMAIN=crm.seudominio.com
ACME_EMAIL=seuemail@dominio.com

# Banco de dados PostgreSQL
# Usuário: sempre 'postgres' (superusuário padrão da imagem Docker, não é configurável)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=gere_com_openssl_rand_hex_32

# Redis
# Redis não usa nome de usuário — somente senha
REDIS_PASSWORD=gere_com_openssl_rand_hex_32

# Segurança da aplicação
# JWT_SECRET e INTERNAL_TOKEN devem ser DIFERENTES entre si
# META_CLOUD_SERVICE_TOKEN: token INTERNO gerado por você (NÃO é da Meta/Facebook)
JWT_SECRET=gere_com_openssl_rand_hex_32
INTERNAL_TOKEN=gere_com_openssl_rand_hex_32
META_CLOUD_SERVICE_TOKEN=gere_com_openssl_rand_hex_32

# Storage de mídia: local ou s3
# Padrão: local (arquivos salvos no disco da VPS)
# Para usar S3/Backblaze/R2/MinIO, mude para: s3
STORAGE_TYPE=local

# AWS S3 ou S3 compatível (Backblaze B2, MinIO, Cloudflare R2, DigitalOcean Spaces...)
# Preencha apenas se STORAGE_TYPE=s3
#AWS_ACCESS_KEY_ID=sua_access_key
#AWS_SECRET_ACCESS_KEY=sua_secret_key
#AWS_REGION=us-east-005
#AWS_S3_BUCKET_NAME=nome_do_bucket
#AWS_S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
# Use true para S3 compatível (Backblaze, MinIO, R2); false para AWS S3 padrão
#AWS_S3_FORCE_PATH_STYLE=true
