# =============================================================
# SofiaCRM — Exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais
# Gere senhas/tokens com: openssl rand -hex 32
# =============================================================

# =============================================================
# EDIÇÃO — definido automaticamente pelo script
# free = edição comunitária gratuita
# pro  = edição profissional (requer licença)
# =============================================================
CRM_EDITION=free

# =============================================================
# ACESSO PÚBLICO — domínio e SSL
# =============================================================
CRM_DOMAIN=crm.seudominio.com
ACME_EMAIL=seuemail@dominio.com

# =============================================================
# BANCO DE DADOS — PostgreSQL
# Usuário: sempre 'postgres' (superusuário padrão da imagem Docker, não é configurável)
# =============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=gere_com_openssl_rand_hex_32

# =============================================================
# CACHE — Redis
# Redis não usa nome de usuário — somente senha
# =============================================================
REDIS_PASSWORD=gere_com_openssl_rand_hex_32

# =============================================================
# SEGURANÇA — tokens internos
# JWT_SECRET: assina os tokens de sessão dos usuários do CRM
# INTERNAL_TOKEN: autentica chamadas internas crm_api <-> whats-service
# META_CLOUD_SERVICE_TOKEN: token INTERNO entre crm_api <-> meta-cloud-service
#   (NÃO é da Meta/Facebook — é gerado por você para comunicação entre containers)
# JWT_SECRET e INTERNAL_TOKEN devem ser DIFERENTES entre si
# =============================================================
JWT_SECRET=gere_com_openssl_rand_hex_32
INTERNAL_TOKEN=gere_com_openssl_rand_hex_32
META_CLOUD_SERVICE_TOKEN=gere_com_openssl_rand_hex_32

# =============================================================
# STORAGE DE MÍDIA
# local = arquivos salvos no disco da VPS (padrão, mais simples)
# s3    = Backblaze B2, AWS S3, Cloudflare R2, MinIO...
# =============================================================
STORAGE_TYPE=local

# Preencha apenas se STORAGE_TYPE=s3
#AWS_ACCESS_KEY_ID=sua_access_key
#AWS_SECRET_ACCESS_KEY=sua_secret_key
#AWS_REGION=us-east-005
#AWS_S3_BUCKET_NAME=nome_do_bucket
#AWS_S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
# Use true para S3 compatível (Backblaze, MinIO, R2); false para AWS S3 padrão
#AWS_S3_FORCE_PATH_STYLE=true

# =============================================================
# PRO — preencha apenas se CRM_EDITION=pro
# LICENSE_TOKEN: chave de ativação da licença Pro (fornecido na compra)
# VPS_PUBLIC_IP: IP público da VPS (usado pelo wa-call-gateway para chamadas de voz)
# =============================================================
#LICENSE_TOKEN=seu_token_de_licenca
#VPS_PUBLIC_IP=203.0.113.10

# =============================================================
# n8n — automação de workflows (opcional, instalado via opção 5)
# N8N_DOMAIN: subdomínio exclusivo para o n8n (DNS deve apontar para esta VPS)
# N8N_ENCRYPTION_KEY: gerada automaticamente pelo script. Nunca altere após instalar!
# =============================================================
#N8N_DOMAIN=n8n.seudominio.com
#N8N_ENCRYPTION_KEY=gere_com_openssl_rand_hex_32
